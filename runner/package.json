    "format": "prettier -w ."
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/node": "^25.3.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "playwright": "1.58.2",
    "ts-node": "^10.9.2",
    "typescript": "5.6.3"
  },
  "dependencies": {
    "uuid": "^13.0.0"
  }
}
