{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SummaryReport",
  "type": "object",
  "required": ["run", "config", "evidence", "findings", "uiCoverage", "metrics", "runMetadata"],
  "properties": {
    "run": {
      "type": "object",
      "required": ["runId", "url", "startedAt", "finishedAt", "runnerVersion", "status"],
      "properties": {
        "runId": { "type": "string" },
        "url": { "type": "string" },
        "startedAt": { "type": "string" },
        "finishedAt": { "type": "string" },
        "runnerVersion": { "type": "string" },
        "status": { "type": "string", "enum": ["ok", "blocked"] }
      },
      "additionalProperties": true
    },
    "config": {
      "type": "object",
      "required": ["browser", "headless", "safeMode", "maxLinks", "strict"],
      "properties": {
        "browser": { "type": "string" },
        "headless": { "type": "boolean" },
        "safeMode": { "type": "boolean" },
        "maxLinks": { "type": "number" },
        "strict": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "evidence": {
      "type": "object",
      "required": ["consoleLogPath", "networkLogPath", "requestFailedPath"],
      "properties": {
        "screenshot": { "type": ["string", "null"] },
        "trace": { "type": ["string", "null"] },
        "consoleLogPath": { "type": "string" },
        "networkLogPath": { "type": "string" },
        "requestFailedPath": { "type": "string" }
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ruleId", "severity", "category", "title"],
        "properties": {
          "ruleId": { "type": "string" },
          "severity": { "type": "string" },
          "category": { "type": "string" },
          "title": { "type": "string" },
          "detail": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "uiCoverage": {
      "type": "object",
      "required": ["totalElements", "testedElements", "skippedElements", "failedElements", "attemptedNoEffectElements"],
      "properties": {
        "totalElements": { "type": "number" },
        "testedElements": { "type": "number" },
        "skippedElements": { "type": "number" },
        "failedElements": { "type": "number" },
        "attemptedNoEffectElements": { "type": "number" },
        "topSkipReasons": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["reason", "count"],
            "properties": {
              "reason": { "type": "string" },
              "count": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "byStatus": { "type": "object", "additionalProperties": { "type": "number" } },
        "byReasonCode": { "type": "object", "additionalProperties": { "type": "number" } },
        "topReasonCodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["reasonCode", "count"],
            "properties": {
              "reasonCode": { "type": "string" },
              "count": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "topActionableItems": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["elementId", "reasonCode", "actionHint"],
            "properties": {
              "elementId": { "type": "string" },
              "reasonCode": { "type": "string" },
              "actionHint": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "actionableGaps": { "type": "number" }
      },
      "additionalProperties": true
    },
    "metrics": {
      "type": "object",
      "properties": {
        "durationMs": { "type": ["number", "null"] },
        "linkSampled": { "type": "number" },
        "linkBroken": { "type": "number" },
        "consoleErrors": { "type": "number" },
        "consoleWarnings": { "type": "number" },
        "response4xx5xx": { "type": "number" },
        "requestFailed": { "type": "number" }
      },
      "additionalProperties": true
    },
    "runMetadata": {
      "type": "object",
      "properties": {
        "nodeVersion": { "type": "string" },
        "platform": { "type": "string" },
        "playwrightVersion": { "type": ["string", "null"] }
      },
      "required": ["nodeVersion", "platform"],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

